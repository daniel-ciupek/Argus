# ── Application ──────────────────────────────────────────────
APP_NAME="Hermes Cockpit"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── Logging ─────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database (PostgreSQL) ───────────────────────────────────
# Host names match the service names from docker-compose.yml.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hermes
DB_USERNAME=hermes
DB_PASSWORD=secret

# ── Cache, queue & session (Redis) ──────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Broadcasting (Laravel Reverb) ───────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=hermes
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Values exposed to the Vite/Echo frontend.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Mail (placeholder) ──────────────────────────────────────
MAIL_MAILER=log
